{
  "dependencies": {
    "ags": "*",
    "gnim": "*"
  },
  "prettier": {
    "semi": false,
    "tabWidth": 2
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.0",
    "globals": "^17.3.0",
    "nodemon": "^3.1.10",
    "typescript-eslint": "^8.56.0"
  },
  "scripts": {
    "build": "ags bundle app.ts ./builds/app -d \"DATADIR='/home/pascal/.config/ags'\"",
    "precopy": "npm run build",
    "copy": "mkdir -p ~/.config/ags && cp -r ./builds/app ./awk ./images ~/.config/ags/",
    "dev": "nodemon --watch app.ts --watch widget --watch style.scss --watch awk --ext ts,tsx,scss,awk --exec \"ags quit || true; npm run copy && ~/.config/ags/app\"",
    "prestart:bg": "npm run copy",
    "start:bg": "sh -c 'nohup ~/.config/ags/app >/tmp/ags-bar.log 2>&1 &'"
  }
}
